@page "/login"
@layout Layout.AuthLayout
@implements IDisposable
@inject NavigationManager Navigation
@inject AccountDirectory Accounts
@inject AuthSession Session
@inject LanguageService Loc

<PageTitle>@Loc.Text("Đăng nhập", "Sign in")</PageTitle>

<div class="auth-shell">
    <section class="auth-visual">
        <div class="auth-brand-stack">
            <img class="auth-logo" src="dscity-logo.png" alt="Logo DSCITY" />
            <h1>DSCITY</h1>
            <p>@Loc.Text("Kết nối thông minh. Di chuyển thuận tiện.", "Smart connections. Seamless mobility.")</p>
        </div>
        <div class="auth-skyline"></div>
    </section>

    <section class="auth-card">
        <div class="auth-card-top">
            <div class="language-switcher" role="group" aria-label="Language switcher">
                <button class="lang-button @(Loc.IsEnglish ? null : "active")" type="button" @onclick="() => SetLanguage(false)">VI</button>
                <button class="lang-button @(Loc.IsEnglish ? "active" : null)" type="button" @onclick="() => SetLanguage(true)">EN</button>
            </div>
        </div>

        <div class="auth-copy">
            <p class="eyebrow">@Loc.Text("Chào mừng đến với DSCITY", "Welcome to DSCITY")</p>
            <h2>@Loc.Text("Đăng nhập quản trị", "Administrator sign in")</h2>
        </div>

        @if (!string.IsNullOrWhiteSpace(feedbackMessage))
        {
            <div class="feedback-banner">@feedbackMessage</div>
        }

        <form class="field-stack auth-form" @onsubmit="HandleSubmitAsync">
            <label class="field-group"><span>@Loc.Text("Số điện thoại", "Phone number")</span><input @bind="phone" /></label>
            <label class="field-group"><span>@Loc.Text("Mật khẩu", "Password")</span><input type="password" @bind="password" /></label>

            <button class="btn btn-hero-primary auth-submit" type="submit">
                @Loc.Text("Đăng nhập", "Sign in")
            </button>
        </form>

        <p class="auth-hint">@Loc.Text("Tài khoản mẫu: 0123456789 / 123456", "Demo account: 0123456789 / 123456")</p>
    </section>
</div>

@code {
    private string phone = string.Empty;
    private string password = string.Empty;
    private string? feedbackMessage;

    protected override void OnInitialized()
    {
        Loc.OnChange += HandleLanguageChanged;
        Session.OnChange += HandleSessionChanged;
    }

    private void SetLanguage(bool isEnglish) => Loc.SetEnglish(isEnglish);

    private async Task HandleSubmitAsync()
    {
        await LoginAsync();
    }

    private Task LoginAsync()
    {
        if (!Accounts.ValidateCredentials(phone, password, out var user) || user is null)
        {
            feedbackMessage = Loc.Text("Sai số điện thoại hoặc mật khẩu.", "Incorrect phone number or password.");
            return Task.CompletedTask;
        }

        Session.SignIn(user);
        Navigation.NavigateTo("/", replace: true);
        return Task.CompletedTask;
    }

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);
    private void HandleSessionChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Loc.OnChange -= HandleLanguageChanged;
        Session.OnChange -= HandleSessionChanged;
    }
}
