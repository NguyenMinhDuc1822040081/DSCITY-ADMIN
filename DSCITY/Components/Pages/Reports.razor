@page "/reports"
@implements IDisposable
@inject LanguageService Loc

<PageTitle>@Loc.Text("Báo cáo", "Reports")</PageTitle>

<section class="page-header-card">
    <div>
        <p class="eyebrow">@Loc.Text("Báo cáo", "Reports")</p>
        <h1>@Loc.Text("Báo cáo, cảnh báo và sức khỏe vận hành", "Reports, alerts, and operational health")</h1>
        <p>@Loc.Text("Quan sát tốc độ xử lý hồ sơ, tỷ lệ ký thành công và hợp đồng sắp hết hạn.", "Monitor dossier processing speed, signing success rates, and contracts nearing expiration.")</p>
    </div>
</section>

<section class="stats-grid">
    <article class="stat-card compact"><span class="stat-label">@Loc.Text("Tỷ lệ ký thành công", "Signing success rate")</span><strong>84%</strong><p>@Loc.Text("+6% so với tháng trước", "+6% compared with last month")</p></article>
    <article class="stat-card compact"><span class="stat-label">@Loc.Text("Thời gian xử lý TB", "Average processing time")</span><strong>@Loc.Text("3,8 ngày", "3.8 days")</strong><p>@Loc.Text("Mục tiêu 4,5 ngày", "Target: 4.5 days")</p></article>
    <article class="stat-card compact"><span class="stat-label">@Loc.Text("Hợp đồng đến hạn", "Contracts due soon")</span><strong>11</strong><p>@Loc.Text("Cần nhắc trước 30 ngày", "Needs reminders 30 days in advance")</p></article>
    <article class="stat-card compact"><span class="stat-label">@Loc.Text("Tỷ lệ hồ sơ đúng SLA", "On-SLA dossier rate")</span><strong>91%</strong><p>@Loc.Text("Cảnh báo sớm cho 9 hồ sơ", "Early warnings for 9 dossiers")</p></article>
</section>

<section class="panel-card">
    <div class="panel-header">
        <div>
            <p class="eyebrow">@Loc.Text("Cảnh báo", "Alerts")</p>
            <h3>@Loc.Text("Danh sách ưu tiên cần xử lý", "Priority items to address")</h3>
        </div>
    </div>

    <table class="admin-table">
        <thead>
            <tr><th>@Loc.Text("Loại", "Type")</th><th>@Loc.Text("Nội dung", "Details")</th><th>@Loc.Text("Mức độ", "Severity")</th><th>@Loc.Text("Hạn xử lý", "Due date")</th></tr>
        </thead>
        <tbody>
            <tr><td>@Loc.Text("Hợp đồng", "Contract")</td><td>@Loc.Text("4 hợp đồng sắp hết hạn trong 7 ngày", "4 contracts are expiring within 7 days")</td><td><span class="status-pill warning">@Loc.Text("Cần chú ý", "Attention")</span></td><td>08/06/2026</td></tr>
            <tr><td>@Loc.Text("Hồ sơ", "Dossier")</td><td>@Loc.Text("3 hồ sơ đang quá SLA thẩm định pháp lý", "3 dossiers are beyond the legal review SLA")</td><td><span class="status-pill critical">@Loc.Text("Gấp", "Urgent")</span></td><td>@Loc.Text("Hôm nay", "Today")</td></tr>
            <tr><td>@Loc.Text("Công nợ", "Receivables")</td><td>@Loc.Text("2 đối tác chậm đối soát thanh toán", "2 partners are late on payment reconciliation")</td><td><span class="status-pill info">@Loc.Text("Theo dõi", "Monitor")</span></td><td>10/06/2026</td></tr>
        </tbody>
    </table>
</section>

@code {
    protected override void OnInitialized()
    {
        Loc.OnChange += HandleLanguageChanged;
    }

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Loc.OnChange -= HandleLanguageChanged;
    }
}
