@page "/approvals"

<PageTitle>Phê duyệt</PageTitle>

<section class="page-header-card">
    <div>
        <p class="eyebrow">Luồng phê duyệt</p>
        <h1>Hàng đợi phê duyệt nội bộ</h1>
        <p>Tập trung các mục cần phê duyệt bởi Kinh doanh, Pháp chế, Tài chính và Quản trị viên cấp cao.</p>
    </div>
</section>

<section class="content-grid">
    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Chờ duyệt</p>
                <h3>Danh sách công việc</h3>
            </div>
        </div>

        <div class="task-list">
            <div class="task-item critical"><div><strong>Điều chỉnh mức chia sẻ doanh thu cho Central Plaza Parking</strong><p>Cần tài chính phê duyệt trước khi gửi bản cuối cho đối tác.</p></div><span>Tài chính</span></div>
            <div class="task-item"><div><strong>Xác minh giấy ủy quyền của Skyline Mobility</strong><p>Pháp chế cần kết luận trước 15:00 hôm nay.</p></div><span>Pháp chế</span></div>
            <div class="task-item"><div><strong>Duyệt kích hoạt đối tác Urban Charge Hub</strong><p>Đã ký xong, còn bước phê duyệt go-live.</p></div><span>Vận hành</span></div>
        </div>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Ma trận phê duyệt</p>
                <h3>Luồng tham chiếu</h3>
            </div>
        </div>

        <div class="pipeline-list">
            <div class="pipeline-row"><span>Quản trị kinh doanh</span><strong>Tạo và hoàn thiện hồ sơ</strong></div>
            <div class="pipeline-row"><span>Quản trị pháp chế</span><strong>Rà soát pháp lý và điều khoản</strong></div>
            <div class="pipeline-row"><span>Quản trị tài chính</span><strong>Xác nhận biểu phí và công nợ</strong></div>
            <div class="pipeline-row"><span>Quản trị viên cấp cao</span><strong>Phê duyệt kích hoạt cuối</strong></div>
        </div>
    </article>
</section>
