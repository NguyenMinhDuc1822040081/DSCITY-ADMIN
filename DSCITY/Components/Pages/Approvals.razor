@page "/approvals"
@implements IDisposable
@inject LanguageService Loc

<PageTitle>@Loc.Text("Phê duyệt", "Approvals")</PageTitle>

<section class="page-header-card">
    <div>
        <p class="eyebrow">@Loc.Text("Luồng phê duyệt", "Approval flow")</p>
        <h1>@Loc.Text("Hàng đợi phê duyệt nội bộ", "Internal approval queue")</h1>
        <p>@Loc.Text("Tập trung các mục cần phê duyệt bởi Kinh doanh, Pháp chế, Tài chính và Quản trị viên cấp cao.", "Centralize items that need approval from Sales, Legal, Finance, and senior administrators.")</p>
    </div>
</section>

<section class="content-grid">
    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">@Loc.Text("Chờ duyệt", "Pending approval")</p>
                <h3>@Loc.Text("Danh sách công việc", "Task list")</h3>
            </div>
        </div>

        <div class="task-list">
            <div class="task-item critical"><div><strong>@Loc.Text("Điều chỉnh mức chia sẻ doanh thu cho Central Plaza Parking", "Adjust the revenue share for Central Plaza Parking")</strong><p>@Loc.Text("Cần tài chính phê duyệt trước khi gửi bản cuối cho đối tác.", "Needs finance approval before sending the final version to the partner.")</p></div><span>@Loc.Text("Tài chính", "Finance")</span></div>
            <div class="task-item"><div><strong>@Loc.Text("Xác minh giấy ủy quyền của Skyline Mobility", "Verify the power of attorney for Skyline Mobility")</strong><p>@Loc.Text("Pháp chế cần kết luận trước 15:00 hôm nay.", "Legal needs a conclusion before 15:00 today.")</p></div><span>@Loc.Text("Pháp chế", "Legal")</span></div>
            <div class="task-item"><div><strong>@Loc.Text("Duyệt kích hoạt đối tác Urban Charge Hub", "Approve the activation of partner Urban Charge Hub")</strong><p>@Loc.Text("Đã ký xong, còn bước phê duyệt go-live.", "Already signed; only the go-live approval remains.")</p></div><span>@Loc.Text("Vận hành", "Operations")</span></div>
        </div>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">@Loc.Text("Ma trận phê duyệt", "Approval matrix")</p>
                <h3>@Loc.Text("Luồng tham chiếu", "Reference flow")</h3>
            </div>
        </div>

        <div class="pipeline-list">
            <div class="pipeline-row"><span>@Loc.Text("Quản trị kinh doanh", "Business admin")</span><strong>@Loc.Text("Tạo và hoàn thiện hồ sơ", "Create and complete the dossier")</strong></div>
            <div class="pipeline-row"><span>@Loc.Text("Quản trị pháp chế", "Legal admin")</span><strong>@Loc.Text("Rà soát pháp lý và điều khoản", "Review legal aspects and terms")</strong></div>
            <div class="pipeline-row"><span>@Loc.Text("Quản trị tài chính", "Finance admin")</span><strong>@Loc.Text("Xác nhận biểu phí và công nợ", "Confirm fee schedule and receivables")</strong></div>
            <div class="pipeline-row"><span>@Loc.Text("Quản trị viên cấp cao", "Senior administrator")</span><strong>@Loc.Text("Phê duyệt kích hoạt cuối", "Approve the final activation")</strong></div>
        </div>
    </article>
</section>

@code {
    protected override void OnInitialized()
    {
        Loc.OnChange += HandleLanguageChanged;
    }

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Loc.OnChange -= HandleLanguageChanged;
    }
}
