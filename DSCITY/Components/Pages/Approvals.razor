            <div class="pipeline-row"><span>Sales Admin</span><strong>Tao va hoan thien ho so</strong></div>
            <div class="pipeline-row"><span>Legal Admin</span><strong>Rao soat phap ly va dieu khoan</strong></div>
            <div class="pipeline-row"><span>Finance Admin</span><strong>Xac nhan bieu phi va cong no</strong></div>
