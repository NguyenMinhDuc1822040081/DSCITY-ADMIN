@page "/"
@implements IDisposable
@inject LanguageService Loc

<PageTitle>@Loc.Text("Bảng điều khiển", "Dashboard")</PageTitle>

<section class="hero-panel">
    <div>
        <p class="eyebrow">@Loc.Text("Bảng điều khiển quản trị", "Admin dashboard")</p>
        <h1>@Loc.Text("Quản trị doanh nghiệp hợp tác và đăng ký hợp đồng", "Manage partner companies and contract registrations")</h1>
        <p class="hero-copy">
            @Loc.Text("Theo dõi hồ sơ đăng ký, hợp đồng sắp hết hạn, công việc chờ phê duyệt và sức khỏe vận hành của hệ sinh thái đối tác DSCITY.", "Track registrations, expiring contracts, pending approvals, and the operational health of the DSCITY partner ecosystem.")
        </p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-hero-primary" href="companies">@Loc.Text("Mở danh sách đối tác", "Open partner list")</a>
        <a class="btn btn-hero-secondary" href="contracts">@Loc.Text("Xem hợp đồng", "View contracts")</a>
    </div>
</section>

<section class="stats-grid">
    <article class="stat-card">
        <span class="stat-label">@Loc.Text("Doanh nghiệp đang hoạt động", "Active companies")</span>
        <strong>128</strong>
        <p>@Loc.Text("+14 doanh nghiệp mới trong 30 ngày", "+14 new companies in 30 days")</p>
    </article>
    <article class="stat-card">
        <span class="stat-label">@Loc.Text("Hồ sơ chờ thẩm định", "Pending reviews")</span>
        <strong>23</strong>
        <p>@Loc.Text("8 hồ sơ cần bổ sung tài liệu", "8 dossiers need additional documents")</p>
    </article>
    <article class="stat-card">
        <span class="stat-label">@Loc.Text("Hợp đồng sắp hết hạn", "Expiring contracts")</span>
        <strong>11</strong>
        <p>@Loc.Text("4 hợp đồng cần gia hạn trong 7 ngày", "4 contracts need renewal within 7 days")</p>
    </article>
    <article class="stat-card">
        <span class="stat-label">@Loc.Text("Giá trị hợp đồng tháng này", "Contract value this month")</span>
        <strong>12.4B</strong>
        <p>@Loc.Text("Tỷ lệ chốt hợp đồng tăng 18%", "Closing rate is up 18%")</p>
    </article>
</section>

<section class="content-grid">
    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">@Loc.Text("Tiến trình đăng ký", "Registration pipeline")</p>
                <h3>@Loc.Text("Trạng thái hồ sơ", "Dossier status")</h3>
            </div>
            <span class="badge-soft">@Loc.Text("Cập nhật lúc 09:30", "Updated at 09:30")</span>
        </div>

        <div class="pipeline-list">
            <div class="pipeline-row"><span>@Loc.Text("Tiếp nhận hồ sơ", "Intake")</span><strong>39</strong></div>
            <div class="pipeline-row"><span>@Loc.Text("Kiểm tra pháp lý", "Legal review")</span><strong>18</strong></div>
            <div class="pipeline-row"><span>@Loc.Text("Chờ phê duyệt nội bộ", "Pending internal approval")</span><strong>9</strong></div>
            <div class="pipeline-row"><span>@Loc.Text("Chờ ký hợp đồng", "Pending signature")</span><strong>6</strong></div>
            <div class="pipeline-row"><span>@Loc.Text("Đã kích hoạt", "Activated")</span><strong>52</strong></div>
        </div>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">@Loc.Text("Ưu tiên hôm nay", "Today priorities")</p>
                <h3>@Loc.Text("Công việc cần xử lý ngay", "Tasks requiring immediate attention")</h3>
            </div>
        </div>

        <div class="task-list">
            <div class="task-item critical">
                <div>
                    <strong>@Loc.Text("Gia hạn hợp đồng với Central Plaza Parking", "Renew the contract with Central Plaza Parking")</strong>
                    <p>@Loc.Text("Hết hạn sau 2 ngày, cần pháp chế và tài chính đồng ý.", "Expires in 2 days and needs legal and finance approval.")</p>
                </div>
                <span>@Loc.Text("SLA gấp", "Urgent SLA")</span>
            </div>
            <div class="task-item">
                <div>
                    <strong>@Loc.Text("Bổ sung GPKD cho Skyline Mobility", "Add business license for Skyline Mobility")</strong>
                    <p>@Loc.Text("Hồ sơ đang chờ đối tác cấp bản công chứng mới.", "Waiting for the partner to provide a new notarized copy.")</p>
                </div>
                <span>@Loc.Text("Đang đợi", "Waiting")</span>
            </div>
            <div class="task-item">
                <div>
                    <strong>@Loc.Text("Phê duyệt biểu phí hợp tác Q3", "Approve the Q3 partnership fee table")</strong>
                    <p>@Loc.Text("Cần xác nhận bộ phận kinh doanh trước 17:00.", "Needs business confirmation before 17:00.")</p>
                </div>
                <span>@Loc.Text("Nội bộ", "Internal")</span>
            </div>
        </div>
    </article>
</section>

<section class="content-grid lower-grid">
    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">@Loc.Text("Đối tác nổi bật", "Featured partners")</p>
                <h3>@Loc.Text("Doanh nghiệp tiêu biểu", "Highlight companies")</h3>
            </div>
        </div>

        <table class="admin-table">
            <thead>
                <tr><th>@Loc.Text("Doanh nghiệp", "Company")</th><th>@Loc.Text("Lĩnh vực", "Category")</th><th>@Loc.Text("Trạng thái", "Status")</th><th>@Loc.Text("Hợp đồng", "Contract")</th></tr>
            </thead>
            <tbody>
                <tr><td>Central Plaza Parking</td><td>@Loc.Translate("Bãi đỗ xe thông minh")</td><td><span class="status-pill success">@Loc.Translate("Hoạt động")</span></td><td>@Loc.Text("Gia hạn 06/2026", "Renewal 06/2026")</td></tr>
                <tr><td>Skyline Mobility</td><td>@Loc.Translate("Cho thuê xe điện")</td><td><span class="status-pill warning">@Loc.Translate("Chờ bổ sung")</span></td><td>@Loc.Translate("Bản nháp")</td></tr>
                <tr><td>Urban Charge Hub</td><td>@Loc.Text("Trạm sạc", "Charging hub")</td><td><span class="status-pill info">@Loc.Translate("Chờ ký")</span></td><td>V2.1</td></tr>
            </tbody>
        </table>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">@Loc.Text("Tiến độ ký kết", "Signing timeline")</p>
                <h3>@Loc.Text("Timeline hợp đồng mẫu", "Sample contract timeline")</h3>
            </div>
        </div>

        <div class="timeline">
            <div class="timeline-item done"><strong>@Loc.Text("Tạo hồ sơ đối tác", "Create partner dossier")</strong><p>@Loc.Text("06/06/2026 - Quản trị kinh doanh", "06/06/2026 - Business admin")</p></div>
            <div class="timeline-item done"><strong>@Loc.Text("Thẩm định pháp lý", "Legal review")</strong><p>@Loc.Text("06/06/2026 - Quản trị pháp chế", "06/06/2026 - Legal admin")</p></div>
            <div class="timeline-item active"><strong>@Loc.Text("Trình ký hợp đồng", "Send contract for signature")</strong><p>@Loc.Text("07/06/2026 - Chờ đại diện doanh nghiệp", "07/06/2026 - Waiting for company representative")</p></div>
            <div class="timeline-item"><strong>@Loc.Text("Kích hoạt hợp tác", "Activate partnership")</strong><p>@Loc.Text("Dự kiến sau khi ký xong", "Expected after signing is complete")</p></div>
        </div>
    </article>
</section>




@code {
    protected override void OnInitialized()
    {
        Loc.OnChange += HandleLanguageChanged;
    }

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Loc.OnChange -= HandleLanguageChanged;
    }
}
