@page "/"

<PageTitle>Dashboard</PageTitle>

<section class="hero-panel">
    <div>
        <p class="eyebrow">Admin dashboard</p>
        <h1>Quan tri doanh nghiep hop tac va dang ky hop dong</h1>
        <p class="hero-copy">
            Theo doi ho so dang ky, hop dong sap het han, cong viec cho phe duyet va suc khoe van hanh cua he sinh thai doi tac DSCITY.
        </p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-hero-primary" href="companies">Mo danh sach doi tac</a>
        <a class="btn btn-hero-secondary" href="contracts">Xem hop dong</a>
    </div>
</section>

<section class="stats-grid">
    <article class="stat-card">
        <span class="stat-label">Doanh nghiep dang hoat dong</span>
        <strong>128</strong>
        <p>+14 doanh nghiep moi trong 30 ngay</p>
    </article>
    <article class="stat-card">
        <span class="stat-label">Ho so cho tham dinh</span>
        <strong>23</strong>
        <p>8 ho so can bo sung tai lieu</p>
    </article>
    <article class="stat-card">
        <span class="stat-label">Hop dong sap het han</span>
        <strong>11</strong>
        <p>4 hop dong can gia han trong 7 ngay</p>
    </article>
    <article class="stat-card">
        <span class="stat-label">Gia tri hop dong thang nay</span>
        <strong>12.4B</strong>
        <p>Ty le chot hop dong tang 18%</p>
    </article>
</section>

<section class="content-grid">
    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Pipeline dang ky</p>
                <h3>Trang thai ho so</h3>
            </div>
            <span class="badge-soft">Cap nhat luc 09:30</span>
        </div>

        <div class="pipeline-list">
            <div class="pipeline-row"><span>Tiep nhan ho so</span><strong>39</strong></div>
            <div class="pipeline-row"><span>Kiem tra phap ly</span><strong>18</strong></div>
            <div class="pipeline-row"><span>Cho phe duyet noi bo</span><strong>9</strong></div>
            <div class="pipeline-row"><span>Cho ky hop dong</span><strong>6</strong></div>
            <div class="pipeline-row"><span>Da kich hoat</span><strong>52</strong></div>
        </div>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Uu tien hom nay</p>
                <h3>Cong viec can xu ly ngay</h3>
            </div>
        </div>

        <div class="task-list">
            <div class="task-item critical">
                <div>
                    <strong>Gia han hop dong voi Central Plaza Parking</strong>
                    <p>Het han sau 2 ngay, can legal va finance dong y.</p>
                </div>
                <span>SLA gap</span>
            </div>
            <div class="task-item">
                <div>
                    <strong>Bo sung GPKD cho Skyline Mobility</strong>
                    <p>Ho so dang cho doi tac cap ban cong chung moi.</p>
                </div>
                <span>Dang doi</span>
            </div>
            <div class="task-item">
                <div>
                    <strong>Phe duyet bieu phi hop tac Q3</strong>
                    <p>Can xac nhan bo phan kinh doanh truoc 17:00.</p>
                </div>
                <span>Noi bo</span>
            </div>
        </div>
    </article>
</section>

<section class="content-grid lower-grid">
    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Top doi tac</p>
                <h3>Doanh nghiep noi bat</h3>
            </div>
        </div>

        <table class="admin-table">
            <thead>
                <tr><th>Doanh nghiep</th><th>Linh vuc</th><th>Trang thai</th><th>Hop dong</th></tr>
            </thead>
            <tbody>
                <tr><td>Central Plaza Parking</td><td>Bai do xe thong minh</td><td><span class="status-pill success">Hoat dong</span></td><td>Gia han 06/2026</td></tr>
                <tr><td>Skyline Mobility</td><td>Cho thue xe dien</td><td><span class="status-pill warning">Cho bo sung</span></td><td>Ban nhap</td></tr>
                <tr><td>Urban Charge Hub</td><td>Tram sac</td><td><span class="status-pill info">Cho ky</span></td><td>V2.1</td></tr>
            </tbody>
        </table>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Tien do ky ket</p>
                <h3>Timeline hop dong mau</h3>
            </div>
        </div>

        <div class="timeline">
            <div class="timeline-item done"><strong>Tao ho so doi tac</strong><p>06/06/2026 - Sales admin</p></div>
            <div class="timeline-item done"><strong>Tham dinh phap ly</strong><p>06/06/2026 - Legal admin</p></div>
            <div class="timeline-item active"><strong>Trinh ky hop dong</strong><p>07/06/2026 - Cho dai dien doanh nghiep</p></div>
            <div class="timeline-item"><strong>Kich hoat hop tac</strong><p>Du kien sau khi ky xong</p></div>
        </div>
    </article>
</section>
