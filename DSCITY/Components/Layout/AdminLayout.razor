@inherits LayoutComponentBase
@implements IDisposable
@inject LanguageService Loc
@inject AuthSession Session
@inject NavigationManager Navigation

<div class="admin-shell">
    <aside class="admin-sidebar">
        <NavMenu />
    </aside>

    <div class="admin-main">
        <header class="admin-topbar">
            <div>
                <p class="eyebrow">@Loc.Text("Cổng Hợp Tác Doanh Nghiệp", "Enterprise Partnership Portal")</p>
                <h2>DSCITY Admin</h2>
            </div>

            <div class="topbar-meta">
                <div class="language-switcher" role="group" aria-label="Language switcher">
                    <button class="lang-button @(Loc.IsEnglish ? null : "active")" type="button" @onclick="() => SetLanguage(false)">VI</button>
                    <button class="lang-button @(Loc.IsEnglish ? "active" : null)" type="button" @onclick="() => SetLanguage(true)">EN</button>
                </div>
                <a class="user-card user-card-link" href="account">
                    <strong>@(Session.CurrentUser?.FullName ?? "DSCITY")</strong>
                    <span>@(Session.CurrentUser is null ? Loc.Text("Khách", "Guest") : Loc.Text(Session.CurrentUser.Role, Session.CurrentUser.Role == "Quản trị viên cấp cao" ? "Super Admin" : "Partner Admin"))</span>
                </a>
                <button class="btn btn-neutral btn-logout" type="button" @onclick="Logout">@Loc.Text("Đăng xuất", "Sign out")</button>
            </div>
        </header>

        <main class="admin-content">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @Loc.Text("Đã xảy ra lỗi ngoài dự kiến.", "An unexpected error has occurred.")
    <a href="." class="reload">@Loc.Text("Tải lại", "Reload")</a>
    <span class="dismiss">x</span>
</div>

@code {
    protected override void OnInitialized()
    {
        Loc.OnChange += HandleLanguageChanged;
        Session.OnChange += HandleLanguageChanged;
    }

    private void SetLanguage(bool isEnglish) => Loc.SetEnglish(isEnglish);

    private void Logout()
    {
        Session.SignOut();
        Navigation.NavigateTo("/login", replace: true);
    }

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Loc.OnChange -= HandleLanguageChanged;
        Session.OnChange -= HandleLanguageChanged;
    }
}
