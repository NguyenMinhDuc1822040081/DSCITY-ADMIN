@implements IDisposable
@inject LanguageService Loc

<div class="brand-block brand-block-logo">
    <img class="brand-logo" src="dscity-logo.png" alt="Logo DSCITY" />
    <div class="brand-copy">
        <h1>DSCITY</h1>
        <p>@Loc.Text("Cổng quản trị đô thị số thông minh", "Digital smart city admin portal")</p>
    </div>
</div>

<nav class="menu-group">
    <p class="menu-label">@Loc.Text("Tổng quan", "Overview")</p>
    <NavLink class="menu-link" href="" Match="NavLinkMatch.All">
        <span>@Loc.Text("Bảng điều khiển", "Dashboard")</span>
    </NavLink>
</nav>

<nav class="menu-group">
    <p class="menu-label">@Loc.Text("Vận hành", "Operations")</p>
    <NavLink class="menu-link" href="companies">
        <span>@Loc.Text("Doanh nghiệp đối tác", "Partner companies")</span>
    </NavLink>
    <NavLink class="menu-link" href="registrations">
        <span>@Loc.Text("Hồ sơ đăng ký", "Registrations")</span>
    </NavLink>
    <NavLink class="menu-link" href="contracts">
        <span>@Loc.Text("Hợp đồng", "Contracts")</span>
    </NavLink>
    <NavLink class="menu-link" href="approvals">
        <span>@Loc.Text("Phê duyệt", "Approvals")</span>
    </NavLink>
</nav>

<nav class="menu-group">
    <p class="menu-label">@Loc.Text("Báo cáo", "Reports")</p>
    <NavLink class="menu-link" href="reports">
        <span>@Loc.Text("Thống kê và cảnh báo", "Analytics and alerts")</span>
    </NavLink>
</nav>

<nav class="menu-group">
    <p class="menu-label">@Loc.Text("Tài khoản", "Account")</p>
    <NavLink class="menu-link" href="account">
        <span>@Loc.Text("Hồ sơ quản trị viên", "Administrator profile")</span>
    </NavLink>
</nav>

@code {
    protected override void OnInitialized()
    {
        Loc.OnChange += HandleLanguageChanged;
    }

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Loc.OnChange -= HandleLanguageChanged;
    }
}
